{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mcp-bling",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BlingMCP"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "BLING_MCP",
        "class_name": "BlingMCP"
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "PREENCHER_COM_O_ID_DO_KV"
    }
  ]
}
