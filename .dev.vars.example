# Copie para .dev.vars (não versionado) e preencha para rodar `npm run dev`.

# Token compartilhado que autentica os apps chamadores (header Authorization: Bearer ...).
SERVICE_TOKEN=gere_um_token_forte_aqui

# Credenciais do app criado em https://developer.bling.com.br/aplicativos
# (usadas apenas pelo endpoint /token/refresh).
BLING_CLIENT_ID=seu_client_id
BLING_CLIENT_SECRET=seu_client_secret
